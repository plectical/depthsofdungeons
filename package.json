{
  "name": "run-template-2d-react",
  "version": "1.0.0",
  "description": "React + Vite + TypeScript app with RundotGameAPI integration",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "_build": "tsc && vite build",
    "build": "npm run _build",
    "build:bundled": "cross-env RUNDOT_GAME_DISABLE_EMBEDDED_LIBS=true npm run _build",
    "preview": "vite preview",
    "deploy": "npm run build && rundot deploy && rundot game copy-tag development production && rundot game copy-tag production public && rundot game copy-tag production public-live && git add -A && git commit -m \"Build deployed\" && git push",
    "format": "prettier \"{src,public}/**/*.{ts,tsx,js,jsx,json,css,html}\" --write",
    "format:check": "prettier \"{src,public}/**/*.{ts,tsx,js,jsx,json,css,html}\" --check"
  },
  "keywords": [
    "react",
    "vite",
    "typescript",
    "RUN.game"
  ],
  "author": "",
  "license": "SEE LICENSE IN LICENSE.txt",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "cross-env": "^7.0.3",
    "prettier": "^3.4.2",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "vite": "^6.3.5"
  },
  "dependencies": {
    "@series-inc/rundot-game-sdk": "^5.9.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@series-inc/rundot-game-sdk"
    ]
  }
}
